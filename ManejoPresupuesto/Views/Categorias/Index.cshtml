@model IEnumerable<Categoria>
@{
	ViewData["Title"] = "Categorias";
}
<h1>Crear categoria </h1>
<h5> La categoría nos permite indicar en que gástamos nuestro dinero,tambien de donde provienene nuestros ingresos </h5>
<a asp-action="Crear" class="btn btn-primary mb-3">Crear Nueva Categoria</a>
<table class="table">
	<thead>
		<tr>
			<th>Acciones</th>
			<th>Nombre</th>
			<th>Tipo</th>
			
		</tr>
	</thead>
	<tbody>
		@foreach (var categoria in Model)
		{
			<tr>
				<td>
					<a asp-action="Editar" asp-route-id="@categoria.Id" class="btn btn-primary">Editar</a>
					<a asp-action="Borrar" asp-route-id="@categoria.Id" class="btn btn-danger">Borrar</a>
				</td>
				<td>
					@categoria.Nombre
					</td>
				<td>
					@categoria.TipoOperacionId.ToString()
					</td>
				
			</tr>
		}
</table>
