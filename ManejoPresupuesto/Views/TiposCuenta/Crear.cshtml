@model ManejoPresupuesto.Models.TipoCuenta
@{
    ViewData["Title"] = "Crear";
}
<h1>Crear tipo cuenta</h1>
<h5>El tipo cuenta se refiere a cómo podemos agrupar cuentas.
    ejemplos: prestá, ps, tarjetas de crédito, etc
</h5>
<div asp-validation-summary="ModelOnly" class="text-danger"></div> 
<form asp-controller="TiposCuenta" asp-action="Crear" method="post"> 
    <div class="mb-3">
        <label asp-for="Nombre" class="form-label">Nombre</label>
        <input type="text" asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Crear</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" /> 
}